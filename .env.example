# Copy to .env and fill in. .env is gitignored.

# Noviplast — GS1 Digital Link API uses OAuth2 client-credentials. The client
# mints a short-lived token from these client_id/client_secret pairs (issued via
# MyGS1 / the developer portal), one pair per environment.
# Test / acceptance (sandbox):
NOVIPLAST_GS1_CLIENT_SANDBOX_ID=
NOVIPLAST_GS1_CLIENT_SANDBOX_SECRET=
# Production:
NOVIPLAST_GS1_CLIENT_ID=
NOVIPLAST_GS1_CLIENT_SECRET=

# WordPress application password. WordPress generates these with spaces
# (six 4-char groups, e.g. "abcd EFGH ijkl MNOP qrst UVWX"), so the value MUST be
# single-quoted — an unquoted value breaks `source .env` on the first space and the
# variable loads empty. Keep the quotes even though the app password has no shell
# metacharacters today.
NOVIPLAST_WP_APP_PASS='xxxx xxxx xxxx xxxx xxxx xxxx'

# --- Staging integration test (pytest -m staging) ----------------------------
# Non-secret test-runner config for tests/integration/test_run_execute_staging.py.
# Nothing auto-loads this file: run `set -a; source .env; set +a` before pytest.
# The run writes a LIVE GS1 production entry + a WP page — use a disposable GTIN.
WP_STAGING_URL=            # e.g. https://staging.noviplast.nl
WP_STAGING_USER=          # WordPress user owning the app password above
GS1_PROD_ACCOUNT=         # GS1 production account number
STAGING_GTIN=             # disposable/pilot GTIN for the smoke run
# Optional: WP_STAGING_POST_TYPE (default noviplast)
