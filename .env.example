# Copy to .env and fill in. .env is gitignored.

# Noviplast — GS1 Digital Link API uses OAuth2 client-credentials. The client
# mints a short-lived token from these client_id/client_secret pairs (issued via
# MyGS1 / the developer portal), one pair per environment.
# Test / acceptance (sandbox):
NOVIPLAST_GS1_CLIENT_SANDBOX_ID=
NOVIPLAST_GS1_CLIENT_SANDBOX_SECRET=
# Production:
NOVIPLAST_GS1_CLIENT_ID=
NOVIPLAST_GS1_CLIENT_SECRET=

# WordPress application password. WordPress generates these with spaces
# (six 4-char groups, e.g. "abcd EFGH ijkl MNOP qrst UVWX"), so the value MUST be
# single-quoted — an unquoted value breaks `source .env` on the first space and the
# variable loads empty. Keep the quotes even though the app password has no shell
# metacharacters today.
NOVIPLAST_WP_APP_PASS='xxxx xxxx xxxx xxxx xxxx xxxx'

# --- Staging integration tests (pytest -m staging) ---------------------------
# Non-secret test-runner config for tests/integration/*_staging.py.
# Nothing auto-loads this file: run `set -a; source .env; set +a` before pytest.
#
# READ THIS BEFORE RUNNING THEM. These tests write to a LIVE WordPress site and the GS1
# PRODUCTION resolver. They clean up after themselves — the page is force-deleted and the
# GS1 entry retracted, even when a test fails — but the GS1 record CANNOT be deleted: the
# v2 API has no DELETE. The most a retract can do is clear its links and disable it, so a
# dead, linkless, disabled record stays on the account forever.
#
# STAGING_GTIN must therefore be a GTIN dedicated to smoke testing and NOTHING else. It is
# guarded twice — the GTIN must sit in the company prefix below, and a pre-flight aborts if
# a page already exists for it that the tests did not create. Neither guard is sufficient
# alone: a real product's GTIN passes the prefix check, and the tests would then overwrite
# its live page and delete it with every ownership guard correctly passing.
WP_STAGING_URL=           # e.g. https://staging.noviplast.nl
WP_STAGING_USER=          # WordPress user owning the app password above
GS1_PROD_ACCOUNT=         # GS1 production account number
STAGING_GTIN=             # disposable GTIN, Noviplast prefix (8713195), NOT a real product.
                          # No default: unset => the staging tests skip.
# Optional:
#   WP_STAGING_POST_TYPE       (default: noviplast)
#   STAGING_GTIN_PREFIX        (default: 8713195 — the allowlisted company prefix)
#   WP_STAGING_APP_PASS_ENV    (default: NOVIPLAST_WP_APP_PASS)
#   GS1_PROD_CLIENT_ID_ENV     (default: NOVIPLAST_GS1_CLIENT_ID)
#   GS1_PROD_CLIENT_SECRET_ENV (default: NOVIPLAST_GS1_CLIENT_SECRET)
# The *_ENV vars hold the NAMES of the env vars carrying the secrets, not the secrets.
#   STAGING_PRODUCTS_JSON      (default: output/noviplast/data/products.json — the export's
#                               product list, used to refuse a GTIN that is a real product.
#                               Written by parse_export; the staging tests FAIL if absent.)
